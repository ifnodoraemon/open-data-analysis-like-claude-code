# LLM 配置 — 只需选一种格式

# 格式一：OpenAI 格式 (适用于 OpenAI / DeepSeek / 硅基流动 / 任何兼容 OpenAI 的服务)
LLM_PROVIDER=openai
LLM_BASE_URL=https://api.openai.com
LLM_API_ENDPOINT=https://api.openai.com/v1/responses
LLM_API_KEY=sk-your-key
LLM_MODEL=gpt-4o
LLM_DEBUG=false
LLM_DEBUG_DIR=./data/llm-debug

# 格式二：Anthropic 格式 (适用于 Anthropic / 任何兼容 Anthropic 的服务)
# LLM_PROVIDER=anthropic
# LLM_BASE_URL=https://api.anthropic.com
# LLM_API_ENDPOINT=https://api.anthropic.com/v1/messages
# LLM_API_KEY=sk-ant-your-key
# LLM_MODEL=claude-sonnet-4-20250514

# 服务配置
SERVER_PORT=8080
PYTHON_MCP_URL=http://python-executor:8081
AUTH_SECRET=replace-with-a-long-random-secret
DEFAULT_USER_ID=admin
DEFAULT_USER_EMAIL=admin
DEFAULT_USER_NAME=Administrator
DEFAULT_USER_PASSWORD=admin@123
DEFAULT_WORKSPACE_ID=workspace_default
DEFAULT_WORKSPACE_NAME=Default Workspace
STORAGE_ROOT=./data/storage
CACHE_ROOT=./data/cache
METADATA_DB_PATH=./data/metadata/app.db
TEMP_DIR=./data/tmp
