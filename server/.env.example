# LLM 配置 — 只需选一种格式

# 格式一：OpenAI 格式 (适用于 OpenAI / DeepSeek / 硅基流动 / 任何兼容 OpenAI 的服务)
LLM_PROVIDER=openai
LLM_BASE_URL=https://api.openai.com
LLM_API_ENDPOINT=https://api.openai.com/v1/responses
LLM_API_KEY=REPLACE_WITH_YOUR_API_KEY
LLM_MODEL=gpt-4o
LLM_DEBUG=false
LLM_DEBUG_DIR=./data/llm-debug

# DeepSeek V4 官方 OpenAI-compatible 配置示例:
# LLM_PROVIDER=openai
# LLM_BASE_URL=https://api.deepseek.com
# LLM_API_ENDPOINT=https://api.deepseek.com/chat/completions
# LLM_MODEL=deepseek-v4-pro

# 格式二：Anthropic 格式 (适用于 Anthropic / 任何兼容 Anthropic 的服务)
# LLM_PROVIDER=anthropic
# LLM_BASE_URL=https://api.anthropic.com
# LLM_API_ENDPOINT=https://api.anthropic.com/v1/messages
# LLM_API_KEY=REPLACE_WITH_YOUR_ANTHROPIC_KEY
# LLM_MODEL=claude-sonnet-4-20250514

# 服务配置
SERVER_PORT=8080
PYTHON_MCP_URL=http://python-executor:8081
PROXY_TOKEN=REPLACE_WITH_A_RANDOM_SECRET
AUTH_SECRET=REPLACE_WITH_A_LONG_RANDOM_SECRET
DEFAULT_USER_ID=example_admin
DEFAULT_USER_EMAIL=admin@example.com
DEFAULT_USER_NAME=Administrator
DEFAULT_USER_PASSWORD=REPLACE_WITH_A_STRONG_PASSWORD
DEFAULT_WORKSPACE_ID=workspace_default
DEFAULT_WORKSPACE_NAME=Default Workspace
STORAGE_ROOT=./data/storage
CACHE_ROOT=./data/cache
METADATA_DB_PATH=./data/metadata/app.db
TEMP_DIR=./data/tmp
